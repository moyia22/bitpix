# =====================================================================
# BitPix + Supabase — variáveis específicas do Supabase
# Copie estes valores para o seu .env (produção/staging). As demais
# variáveis vêm de .env.production.example. Ver SUPABASE_SETUP.md.
# NUNCA versione o .env com segredos reais.
# =====================================================================

# --- Banco (Supabase Postgres) ---------------------------------------
# DATABASE_URL = usada pelo APP em runtime. Use o "Session pooler" (porta 5432):
#   Supabase → Project Settings → Database → Connection string → "Session pooler".
# Suporta prepared statements e é IPv4 (funciona em VPS sem IPv6).
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-SUA_REGIAO.pooler.supabase.com:5432/postgres?sslmode=require

# DIRECT_URL = usada SOMENTE pelas migrations (prisma migrate deploy).
# Conexão direta, sem pooler. Se o seu servidor não tiver IPv6, use também o
# Session pooler aqui (mesmo valor de DATABASE_URL). Caso tenha IPv6, pode usar:
#   postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-SUA_REGIAO.pooler.supabase.com:5432/postgres?sslmode=require

# Pool do node-postgres (o app gerencia o próprio pool). 10 é seguro no Session pooler.
DATABASE_POOL_MAX=10

# --- Storage (Supabase Storage, S3-compatível) -----------------------
# Supabase → Storage → crie um bucket PRIVADO (ex.: bitpix) e gere as
# "S3 Access Keys" em Storage → Settings → S3 Access Keys.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://SEU_PROJECT_REF.supabase.co/storage/v1/s3
S3_REGION=SUA_REGIAO
S3_BUCKET=bitpix
S3_ACCESS_KEY=SUA_S3_ACCESS_KEY
S3_SECRET_KEY=SUA_S3_SECRET_KEY
S3_FORCE_PATH_STYLE=true
# Supabase gerencia a criptografia em repouso; não envie o header SSE.
S3_SERVER_SIDE_ENCRYPTION=none

# --- Redis: NÃO é do Supabase ----------------------------------------
# Use um Redis gerenciado (ex.: Upstash) com autenticação:
REDIS_URL=rediss://default:SUA_SENHA@SEU-HOST.upstash.io:6379
