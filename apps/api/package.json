{
  "name": "@bitpix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/start.js",
  "exports": {
    "./webhook-processor": {
      "types": "./dist/modules/payments/mercado-pago-webhook-processor.d.ts",
      "import": "./dist/modules/payments/mercado-pago-webhook-processor.js"
    },
    "./export-processor": {
      "types": "./dist/modules/reports/export.processor.d.ts",
      "import": "./dist/modules/reports/export.processor.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/start.ts",
    "start": "node dist/start.js",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "@bitpix/contracts": "0.1.0",
    "@bitpix/database": "0.1.0",
    "@fastify/cookie": "11.1.2",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "argon2": "0.45.0",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "5.11.1",
    "mercadopago": "^3.2.0",
    "nodemailer": "9.0.3",
    "pdf-lib": "^1.17.1",
    "prom-client": "15.1.3",
    "qrcode": "^1.5.4",
    "xlsx-populate": "^1.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/nodemailer": "8.0.1",
    "@types/qrcode": "^1.5.6",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.1",
    "vitest": "4.1.10"
  }
}
