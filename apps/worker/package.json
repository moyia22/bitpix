{
  "name": "@bitpix/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/start.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/start.ts",
    "start": "node dist/start.js",
