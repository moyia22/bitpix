# =====================================================================
# BitPix — STAGING (homologação)
# Espelha produção o mais próximo possível. MinIO como S3 local.
# Provider Mercado Pago em conta de teste. TLS via proxy.
# Preencha os segredos por variáveis de ambiente do host / secret manager.
# =====================================================================
NODE_ENV=production
APP_ENV=staging
APP_URL=https://staging.bitpix.example.com
API_URL=http://api:3333
NEXT_PUBLIC_API_URL=https://staging-api.bitpix.example.com
API_PORT=3333

APP_VERSION=0.1.0
APP_COMMIT_SHA=__SET_BY_CI__
APP_BUILD_DATE=__SET_BY_CI__

POSTGRES_DB=bitpix
POSTGRES_USER=bitpix
POSTGRES_PASSWORD=__STRONG_SECRET__
POSTGRES_PORT=5433
DATABASE_URL=postgresql://bitpix:__STRONG_SECRET__@postgres:5432/bitpix?schema=public
# DIRECT_URL: usado só nas migrations (Prisma). Local = igual ao DATABASE_URL.
# Com Supabase, DATABASE_URL = pooler e DIRECT_URL = conexão direta (ver SUPABASE_SETUP.md).
DIRECT_URL=postgresql://bitpix:__STRONG_SECRET__@postgres:5432/bitpix?schema=public
DATABASE_POOL_MAX=10

REDIS_PORT=6380
# Redis DEVE ter autenticação fora de development.
REDIS_URL=redis://default:__REDIS_SECRET__@redis:6379

SESSION_COOKIE_NAME=bitpix_session
SESSION_TTL_HOURS=8
SHUTDOWN_TIMEOUT_MS=30000

# NÃO rode seed de desenvolvimento em staging/produção.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

PROVIDER_CREDENTIALS_ENCRYPTION_KEY=__BASE64_32_BYTES__
PAYMENT_PROVIDER_MODE=real
PAYMENT_PROVIDER_TIMEOUT_MS=8000
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
# Segredo do webhook é configurado por empresa na interface; esta var é fallback.
MERCADO_PAGO_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_BASE_URL=https://staging-api.bitpix.example.com
WEBHOOK_LOCAL_FALLBACK=false
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
WEBHOOK_MAX_ATTEMPTS=8
SSE_MAX_CONNECTIONS_PER_USER=5

# S3 compatível — MinIO em staging.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://minio.staging.internal
S3_REGION=us-east-1
S3_BUCKET=bitpix-staging
S3_ACCESS_KEY=__MINIO_ACCESS__
S3_SECRET_KEY=__MINIO_SECRET__
S3_FORCE_PATH_STYLE=true
S3_SERVER_SIDE_ENCRYPTION=AES256

SMTP_HOST=__SMTP_HOST__
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=__SMTP_USER__
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_FROM=BitPix Staging <no-reply@staging.bitpix.example.com>

REQUIRE_MFA_FOR_PLATFORM=true
REQUIRE_MFA_FOR_ADMINS=true
PASSWORD_RESET_TTL_MINUTES=15
