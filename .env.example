# =====================================================================
# BitPix — modelo base de variáveis de ambiente
# Copie para .env e ajuste. NUNCA versione segredos reais.
# Variantes específicas: .env.development.example / .env.staging.example
# / .env.production.example
# =====================================================================

# --- Ambiente ---------------------------------------------------------
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3333
NEXT_PUBLIC_API_URL=http://localhost:3333
API_PORT=3333
API_HOST_PORT=3333
WEB_HOST_PORT=3000

# Versão exibida em /health/version (preencha no build/CI)
APP_VERSION=0.1.0
APP_COMMIT_SHA=development
APP_BUILD_DATE=unknown

# --- PostgreSQL (publicado só em 127.0.0.1) ---------------------------
POSTGRES_DB=bitpix
POSTGRES_USER=bitpix
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5433
DATABASE_URL=postgresql://bitpix:change-me-local-only@localhost:5433/bitpix?schema=public
DATABASE_POOL_MAX=10

# --- Redis (publicado só em 127.0.0.1; use auth em staging/prod) ------
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# --- Sessões ----------------------------------------------------------
SESSION_COOKIE_NAME=bitpix_session
SESSION_TTL_HOURS=8
SHUTDOWN_TIMEOUT_MS=30000

# --- Seed de desenvolvimento (sem valor padrão intencionalmente) ------
SEED_ADMIN_EMAIL=admin@bitpix.local
SEED_ADMIN_PASSWORD=

# --- Integração de pagamentos ----------------------------------------
# Gere a chave com exatamente 32 bytes em Base64:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=
PAYMENT_PROVIDER_MODE=mock
PAYMENT_PROVIDER_TIMEOUT_MS=8000
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_BASE_URL=http://localhost:3333

# Fallback síncrono de webhook: SOMENTE desenvolvimento. Proibido em produção.
WEBHOOK_LOCAL_FALLBACK=true
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
WEBHOOK_MAX_ATTEMPTS=8

# --- SSE --------------------------------------------------------------
SSE_MAX_CONNECTIONS_PER_USER=5

# --- Armazenamento privado -------------------------------------------
# development: local | staging/production: s3
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=.runtime/storage
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
S3_SERVER_SIDE_ENCRYPTION=AES256

# --- SMTP (obrigatório em produção) ----------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BitPix <no-reply@localhost>

# --- Segurança / MFA / reset -----------------------------------------
# Em produção, o superadmin é obrigado a usar MFA.
REQUIRE_MFA_FOR_PLATFORM=false
REQUIRE_MFA_FOR_ADMINS=false
PASSWORD_RESET_TTL_MINUTES=15
